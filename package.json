{
    "name": "@snailicid3/root",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "\n========== COMMIT >> ==========": "",
        "commit": "pnpm build:self && pnpm exec scope-commit --checked-commit",
        "commit:feat": "pnpm run commit feat",
        "commit:fix": "pnpm run commit fix",
        "commit:chore": "pnpm run commit chore",
        "commit:refactor": "pnpm run commit refactor",
        "commit:test": "pnpm run commit test",
        "commit:build": "pnpm run commit build",
        "commit:docs": "pnpm run commit docs",
        "commit:direct": "pnpm build:self && pnpm exec scope-commit --checked-commit --skip-lint-staged",
        "\n========== BUILD >> ==========": "",
        "build": "pnpm nx:build",
        "build:self": "pnpm exec nx run $npm_package_name:build",
        "nx:build": "pnpm exec nx run-many -t build",
        "\n========== TEST >> ==========": "",
        "test": "pnpm nx:test",
        "nx:test": "pnpm exec nx run-many --target=test",
        "\n========== DOCUMENTATION >> ==========": "",
        "docs:build": "pnpm nx:docs:build",
        "nx:docs:build": "pnpm exec nx run-many -t docs:build",
        "\n========== API REPORT >> ==========": "",
        "api:report": "pnpm exec nx run-many --target=api:report",
        "api:check": "pnpm exec nx run-many --target=api:check",
        "workspace:report": "pnpm --workspace-concurrency=1 --filter './packages/**' --filter './apps/**' exec sh -c 'snail-sh spacer 1; snail-sh kabob \"🐌 $PNPM_PACKAGE_NAME\" \"100%\" magenta; snail-sh spacer 1; knip --directory \"$PWD\" || true';snail-sh spacer 2;",
        "\n========== PUBLISH >> ==========": "",
        "changeset:create": "pnpm changeset:prepare && pnpm exec gbt-changeset && pnpm api:report",
        "changeset:prepare": "pnpm run test && pnpm docs:build",
        "release:archive": "pnpm -r exec mkdir -p ./releases &&  pnpm -r --access public pack --pack-destination='./releases'",
        "registry:start": "pnpm exec verdaccio",
        "\n========== INSPECT >> ==========": "",
        "inspect:nx": "pnpm nx:graph",
        "inspect:lint": "pnpm exec eslint-config-inspector --no-open",
        "inspect:vitest": "pnpm exec vitest --ui",
        "\n========== LIFECYCLE >> ==========": "",
        "start": "pnpm install && pnpm build",
        "uninstall": "pnpm exec gbt-uninstall",
        "setup": "pnpm exec gbt-setup",
        "reset": "pnpm run uninstall && pnpm start",
        "prepare": "husky",
        "lint:staged": "pnpm exec lint-staged --relative",
        "postinstall": "pnpm build:self && echo '\n=== >> Success:: Install complete.'",
        "\n========== NX >> ==========": "",
        "nx:graph": "pnpm nx graph",
        "nx:affected": "nx affected --target=build",
        "nx:reset": "pnpm exec nx reset",
        "\n========== CHECK >> ==========": "",
        "check": "pnpm exec nx run-many -t lint",
        "check:md": "pnpm exec nx run $npm_package_name:lint:md",
        "\n========== FIX >> ==========": "",
        "fix": "pnpm exec nx run-many -t fix",
        "fix:md": "pnpm exec nx run $npm_package_name:fix:md",
        "\n========== CLEAN >> ==========": "",
        "clean": "pnpm exec nx run-many -t clean",
        "clean:self": "pnpm exec nx run $npm_package_name:clean"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@commitlint/cli": "^21.0.2",
        "@eslint/config-inspector": "^3.0.4",
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^26.0.0",
        "@vitest/coverage-v8": "^4.1.9",
        "@vitest/ui": "^4.1.9",
        "eslint": "^10.4.1",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "knip": "^6.18.0",
        "lint-staged": "^16.4.0",
        "markdownlint-cli2": "^0.22.0",
        "nx": "^23.0.0",
        "prettier": "^3.8.4",
        "tsx": "^4.22.4",
        "typescript": "^6.0.2",
        "verdaccio": "^6.7.4"
    },
    "nx": {
        "includedScripts": []
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3-monorepo"
    },
    "packageManager": "pnpm@10.30.2",
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=10.30.2 <11"
    },
    "type": "module"
}
