{
    "name": "@snailicid3/root",
    "version": "0.0.0",
    "private": true,
    "description": "snailicid3 monorepo",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3-monorepo"
    },
    "packageManager": "pnpm@10.30.2",
    "engines": {
        "node": ">=20.x",
        "pnpm": ">=10.0.0"
    },
    "type": "module",
    "scripts": {
        "\n========== COMMIT >> ==========": "",
        "commit": "pnpm build:self && pnpm exec scope-commit --checked-commit",
        "commit:cz": "pnpm exec git-cz",
        "commit:direct": "git commit --no-verify -m",
        "lint:staged": "pnpm exec lint-staged --relative",
        "\n========== BUILD >> ==========": "",
        "build": "pnpm nx:build",
        "build:self": "pnpm exec nx run root:build",
        "nx:build": "pnpm exec nx run-many -t build",
        "\n========== TEST >> ==========": "",
        "test": "pnpm nx:test",
        "nx:test": "pnpm exec nx run-many --target=test",
        "\n========== DOCUMENTATION >> ==========": "",
        "docs:build": "pnpm nx:docs:build",
        "nx:docs:build": "pnpm exec nx run-many -t docs:build",
        "\n========== INSPECT >> ==========": "",
        "inspect:nx": "pnpm nx:graph",
        "inspect:lint": "pnpm exec eslint-config-inspector --no-open",
        "inspect:vitest": "pnpm exec vitest --ui",
        "\n========== LIFECYCLE >> ==========": "",
        "start": "pnpm install && pnpm build",
        "uninstall": "pnpm exec gbt-uninstall",
        "setup": "pnpm exec gbt-setup",
        "reset": "pnpm run uninstall && pnpm start",
        "prepare": "husky",
        "postinstall": "pnpm build:self && echo '\n=== >> Success:: Install complete.'",
        "\n========== PUBLISH >> ==========": "",
        "create:changeset": "pnpm pre:changeset && pnpm changeset",
        "pre:changeset": "pnpm run fix && pnpm run test && pnpm docs:build && pnpm exec gbt-changeset && pnpm changeset",
        "release:archive": "pnpm -r exec mkdir -p ./releases &&  pnpm -r --access public pack --pack-destination='./releases'",
        "prerelease": "pnpm exec pnpm run build && pnpm run fix && pnpm run check && pnpm test",
        "registry:start": "pnpm exec verdaccio",
        "\n========== NX >> ==========": "",
        "nx:graph": "pnpm nx graph",
        "nx:affected": "nx affected --target=build",
        "nx:reset": "pnpm exec nx reset",
        "\n========== CHECK >> ==========": "",
        "check": "pnpm exec nx run-many -t lint",
        "check:md": "pnpm exec nx run @snailicid3/root:lint:md",
        "\n========== FIX >> ==========": "",
        "fix": "pnpm exec nx run-many -t fix",
        "fix:md": "pnpm exec nx run @snailicid3/root:fix:md",
        "\n========== CLEAN >> ==========": "",
        "clean": "pnpm exec nx run-many -t clean",
        "\n========== REPORT >> ==========": "",
        "report": "pnpm report:all",
        "report:all": "pnpm report:env && pnpm report:repo && pnpm report:workspace && pnpm report:prettier",
        "report:env": "bash .github/scripts/report-env.sh",
        "report:repo": "bash .github/scripts/report-repo.sh",
        "report:workspace": "bash .github/scripts/report-workspace.sh",
        "report:prettier": "bash .github/scripts/report-prettier.sh",
        "report:scope": "pnpm exec scope-affected",
        "report:affected-scope": "pnpm exec scope-affected",
        "report:commit-scope": "pnpm exec scope-commit"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@commitlint/cz-commitlint": "^20.5.1",
        "@eslint/config-inspector": "^2.0.0",
        "@nx/devkit": "^22.6.5",
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.6.1",
        "@vitest/coverage-v8": "^4.1.5",
        "@vitest/ui": "^4.1.5",
        "attw": "^1.0.0",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^10.2.1",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "lint-staged": "^16.4.0",
        "markdownlint-cli2": "^0.22.0",
        "nx": "^22.6.5",
        "prettier": "^3.8.2",
        "publint": "^0.3.19",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1",
        "unrun": "^0.3.0",
        "verdaccio": "^6.5.0"
    },
    "config": {
        "commitizen": {
            "path": "@commitlint/cz-commitlint"
        }
    },
    "nx": {
        "includedScripts": []
    }
}
