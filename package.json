{
    "name": "snailicid3/root",
    "version": "0.0.0",
    "private": true,
    "description": "snailicid3 monorepo",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3-monorepo"
    },
    "packageManager": "pnpm@10.30.2",
    "engines": {
        "node": ">=20.x",
        "pnpm": ">=10.0.0"
    },
    "scripts": {
        "\n========== COMMIT >> ==========": "",
        "commit": "pnpm commit:before && pnpm exec git-cz",
        "commit:sh": "pnpm exec git commit -m ",
        "commit:before": "pnpm build:self && pnpm lint:staged",
        "commit:direct": "git commit --no-verify -m",
        "lint:staged": "pnpm exec lint-staged --relative",
        "\n========== REPORT >> ==========": "",
        "report": "pnpm report:all",
        "report:all": "pnpm report:env && pnpm report:repo && pnpm report:workspace && pnpm report:prettier",
        "report:env": "python3 packages/workspace-tools/bin/python/env_diagnostics.py",
        "report:repo": "python3 packages/workspace-tools/bin/python/repo_status.py",
        "report:workspace": "pnpm exec tsx packages/workspace-tools/bin/node/workspace-status.ts",
        "report:prettier": "pnpm exec tsx packages/workspace-tools/bin/node/prettier-status.ts",
        "\n========== BUILD >> ==========": "",
        "build": "pnpm nx:build && pnpm build:self",
        "build:self": "pnpm exec tsc -p tsconfig.root.json",
        "nx:build": "pnpm exec nx run-many -t build",
        "nx:build:ts": "pnpm exec nx run-many -t build:ts",
        "nx:build:all": "pnpm exec nx run-many --target=build --all",
        "\n========== TEST >> ==========": "",
        "nx:cmd": "pnpm exec nx run-many --all  --target=nx:test:cmd",
        "test": "pnpm nx:test",
        "nx:test": "pnpm exec nx run-many --target=test",
        "\n========== NX >> ==========": "",
        "nx:graph": "pnpm nx graph",
        "nx:affected": "nx affected --target=build",
        "nx:reset": "pnpm exec nx reset",
        "\n========== INSPECT >> ==========": "",
        "inspect:nx": "pnpm nx:graph",
        "inspect:lint": "pnpm exec eslint-config-inspector",
        "inspect:vitest": "pnpm exec vitest --ui",
        "\n========== LIFECYCLE >> ==========": "",
        "start": "pnpm install && pnpm build",
        "prepare": "husky",
        "postinstall": "echo '\n=== >> Success:: Install complete.'",
        "prune": "pnpm store prune",
        "workspace": "pnpm -r",
        "\n========== PUBLISH >> ==========": "",
        "release": "pnpm run prerelease && pnpm changeset",
        "prerelease": "pnpm run build && pnpm run fix && pnpm run check && pnpm test",
        "\n========== CODE STYLE >> ==========": "",
        "prettier": "prettier {*,**/*}.{ts,tsx,cts,mts,sh,html,json,yaml,yml,md} ./.husky/* --ignore-path ./.gitignore --no-error-on-unmatched-pattern",
        "lint": "eslint --flag unstable_ts_config .",
        "lint:md": "pnpm exec markdownlint-cli2 '{./*,./**/*}.md' '#**/{.history,node_modules,.changeset,docs,scratch}/**'",
        "\n========== CHECK >> ==========": "",
        "check": "pnpm build:self && pnpm check:self",
        "check:md": "pnpm run lint:md",
        "check:self": "pnpm lint && pnpm prettier --check",
        "\n========== FIX >> ==========": "",
        "fix": "pnpm build:self && pnpm fix:self",
        "fix:md": "pnpm run lint:md --fix",
        "fix:self": "pnpm prettier --write && pnpm lint --fix && pnpm fix:md",
        "\n========== CLEAN >> ==========": "",
        "clean": "pnpm clean:self && pnpm nx:clean",
        "clean:self": "pnpm exec tsc --build --clean",
        "nx:clean": "pnpm exec nx run-many -t clean",
        "clean:all": "pnpm nx:clean",
        "\n========== UNINSTALL >> ==========": "",
        "uninstall": "pnpm run clean && pnpm nx:reset && pnpm uninstall:list && pnpm run uninstall:rm && pnpm run uninstall:lock",
        "uninstall:list": "find . -name 'node_modules' -type d -prune",
        "uninstall:rm": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
        "uninstall:lock": "rm -f pnpm-lock.yaml && rm -f packages/**/pnpm-lock.yaml"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@nx/devkit": "^22.6.5",
        "@snailicid3/config": "workspace:*",
        "@snailicide/build-config": "^1.4.4",
        "@types/node": "^25.6.0",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^10.2.0",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "lint-staged": "^16.4.0",
        "markdownlint-cli2": "^0.22.0",
        "nx": "^22.6.5",
        "prettier": "^3.8.2",
        "prettier-plugin-sh": "^0.18.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    }
}
