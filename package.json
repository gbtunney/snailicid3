{
    "name": "@snailicid3/root",
    "version": "0.0.0",
    "private": true,
    "description": "snailicid3 monorepo",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3-monorepo"
    },
    "packageManager": "pnpm@10.30.2",
    "engines": {
        "node": ">=20.x",
        "pnpm": ">=10.0.0"
    },
    "type": "module",
    "scripts": {
        "\n========== COMMIT >> ==========": "",
        "commit": "pnpm commit:before && pnpm exec git-cz",
        "commit:sh": "pnpm exec git commit -m ",
        "commit:before": "pnpm build:self && pnpm lint:staged",
        "commit:direct": "git commit --no-verify -m",
        "lint:staged": "pnpm exec lint-staged --relative",
        "\n========== REPORT >> ==========": "",
        "report": "pnpm report:all",
        "report:all": "pnpm report:env && pnpm report:repo && pnpm report:workspace && pnpm report:prettier",
        "report:env": "python3 packages/workspace-tools/bin/python/env_diagnostics.py",
        "report:repo": "python3 packages/workspace-tools/bin/python/repo_status.py",
        "report:workspace": "pnpm exec tsx packages/workspace-tools/bin/node/workspace-status.ts",
        "report:prettier": "pnpm exec tsx packages/workspace-tools/bin/node/prettier-status.ts",
        "report:scope": "pnpm exec packages/workspace-tools/bin/shell/get-scope.sh",
        "\n========== BUILD >> ==========": "",
        "build": "pnpm nx:build",
        "build:self": "pnpm exec nx run root:build",
        "nx:build": "pnpm exec nx run-many -t build",
        "\n========== DOCUMENTATION >> ==========": "",
        "docs:build": "pnpm nx:docs:build",
        "nx:docs:build": "pnpm exec nx run-many -t docs:build",
        "\n========== TEST >> ==========": "",
        "test": "pnpm nx:test",
        "nx:test": "pnpm exec nx run-many --target=test",
        "\n========== NX >> ==========": "",
        "nx:graph": "pnpm nx graph",
        "nx:affected": "nx affected --target=build",
        "nx:reset": "pnpm exec nx reset",
        "\n========== INSPECT >> ==========": "",
        "inspect:nx": "pnpm nx:graph",
        "inspect:lint": "pnpm exec eslint-config-inspector",
        "inspect:vitest": "pnpm exec vitest --ui",
        "\n========== LIFECYCLE >> ==========": "",
        "start": "pnpm install && pnpm build",
        "reset": "pnpm run uninstall && pnpm start",
        "registry:start": "pnpm exec verdaccio",
        "prepare": "husky",
        "postinstall": "pnpm build:self && echo '\n=== >> Success:: Install complete.'",
        "prune": "pnpm store prune",
        "\n========== PUBLISH >> ==========": "",
        "release": "pnpm run prerelease && pnpm changeset",
        "prerelease": "pnpm run build && pnpm run fix && pnpm run check && pnpm test",
        "\n========== CODE STYLE >> ==========": "",
        "prettier": "prettier {*,**/*}.{ts,tsx,cts,mts,sh,html,json,yaml,yml,md} ./.husky/* --ignore-path ./.gitignore --no-error-on-unmatched-pattern",
        "lint": "pnpm exec nx run root:lint",
        "lint:md": "pnpm exec markdownlint-cli2 '{./*,./**/*}.md' '#**/{.history,node_modules,.changeset,docs,scratch}/**'",
        "\n========== CHECK >> ==========": "",
        "check": "pnpm nx:check",
        "check:self": "pnpm exec nx run root:lint",
        "nx:check": "pnpm exec nx run-many -t lint",
        "check:md": "pnpm exec nx run @snailicid3/root:lint:md",
        "\n========== FIX >> ==========": "",
        "fix": "pnpm nx:fix",
        "nx:fix": "pnpm exec nx run-many -t fix",
        "fix:self": "pnpm exec nx run root:fix",
        "fix:md": "pnpm exec nx run @snailicid3/root:fix:md",
        "\n========== CLEAN >> ==========": "",
        "clean": "pnpm clean:self && pnpm nx:clean",
        "clean:self": "pnpm exec nx run root:clean:ts",
        "nx:clean": "pnpm exec nx run-many -t clean",
        "clean:all": "pnpm nx:clean",
        "\n========== UNINSTALL >> ==========": "",
        "uninstall": "pnpm exec packages/workspace-tools/bin/shell/uninstall.sh"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@commitlint/cz-commitlint": "^20.5.1",
        "@nx/devkit": "^22.6.5",
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.6.0",
        "@vitest/coverage-v8": "^4.1.5",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^10.2.1",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "lint-staged": "^16.4.0",
        "markdownlint-cli2": "^0.22.0",
        "nx": "^22.6.5",
        "prettier": "^3.8.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1",
        "verdaccio": "^6.5.0"
    },
    "config": {
        "commitizen": {
            "path": "@commitlint/cz-commitlint"
        }
    },
    "nx": {
        "includedScripts": []
    }
}
