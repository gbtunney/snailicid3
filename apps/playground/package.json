{
    "name": "@snailicid3/playground",
    "version": "0.0.0",
    "private": true,
    "description": "Development playground app",
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "\n========== DEVELOPMENT >> ==========": "",
        "dev": "vite",
        "dev:vite": "vite",
        "\n========== BUILD >> ==========": "",
        "build:vite": "vite build",
        "\n========== TEST >> ==========": "",
        "test:watch": "vitest watch"
    },
    "devDependencies": {
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.9.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "typescript": "^6.0.2",
        "vite": "^8.0.16",
        "vitest": "^4.1.8"
    },
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:rollup": {},
            "dev:vite": {},
            "build:ts": {
                "command": "echo 'playground: no TS sources'",
                "options": {
                    "cwd": "{projectRoot}"
                }
            },
            "build:rollup": {},
            "build:vite": {},
            "build": {
                "dependsOn": [
                    "build:ts"
                ]
            },
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "type": "module"
}
