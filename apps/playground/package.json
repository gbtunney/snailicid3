{
    "name": "@snailicid3/playground",
    "version": "0.0.0",
    "private": true,
    "description": "Development playground app",
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "\n========== DEVELOPMENT >> ==========": "",
        "dev": "vite",
        "dev:vite": "vite",
        "\n========== TEST >> ==========": "",
        "test:watch": "vitest watch"
    },
    "dependencies": {
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "vite": "^8.0.16"
    },
    "devDependencies": {
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "buildConfig": {
        "runtime": "browser",
        "product": "web_app",
        "buildStrategy": "bundle"
    },
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3",
        "directory": "apps/playground"
    },
    "nx": {
        "targets": {
            "bk:dev": {},
            "dev:ts": {},
            "dev:rollup": {},
            "bk:dev:vite": {},
            "build:ts": {},
            "check:ts": {},
            "build:rollup": {},
            "build:vite": {},
            "build": {
                "dependsOn": [
                    "build:ts",
                    "build:vite"
                ]
            },
            "clean": {},
            "clean:ts": {},
            "clean:build": {},
            "fix": {},
            "lint": {}
        }
    },
    "type": "module"
}
