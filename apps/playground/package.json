{
    "name": "@snailicid3/playground",
    "version": "0.0.0",
    "private": true,
    "description": "Development playground app",
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "\n========== DEVELOPMENT >> ==========": "",
        "dev": "vite",
        "dev:vite": "vite",
        "\n========== BUILD >> ==========": "",
        "build:vite": "vite build",
        "\n========== TEST >> ==========": "",
        "test:watch": "vitest watch"
    },
    "devDependencies": {
        "@snailicid3/config": "workspace:*",
        "@snailicid3/build-config": "workspace:*",
        "@types/node": "^22.0.0",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "typescript": "^5.7.0",
        "vite": "^5.4.0",
        "vitest": "^2.1.0"
    },
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:rollup": {},
            "dev:vite": {},
            "build:ts": {
                "command": "echo 'playground: no TS sources'",
                "options": { "cwd": "{projectRoot}" }
            },
            "build:rollup": {},
            "build:vite": {},
            "build": {
                "dependsOn": [
                    "build:ts"
                ]
            },
            "test": {},
            "test:nx": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {},
            "docs:build": {}
        }
    },
    "type": "module"
}
