{
    "name": "@snailicid3/workspace-tools",
    "version": "0.0.0",
    "private": false,
    "description": "pnpm workspace introspection, repo diagnostics and GitHub issue tooling",
    "scripts": {
        "\n========== DEVELOPMENT >> ==========": "",
        "dev": "tsc --build --watch",
        "\n========== TEST >> ==========": "",
        "test:watch": "vitest watch",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@snailicid3/utils": "workspace:*",
        "@snailicid3/logger": "workspace:*"
    },
    "devDependencies": {
        "@snailicid3/config": "workspace:*",
        "@nx/devkit": "^20.3.0",
        "@types/node": "^22.0.0",
        "typescript": "^5.7.0",
        "vitest": "^2.1.0"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "bin"
    ],
    "nx": {
        "targets": {
            "build:ts": {},
            "build:rollup": {},
            "build:vite": {},
            "build": {
                "dependsOn": [
                    "build:ts"
                ]
            },
            "test": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {},
            "docs:build": {}
        }
    },
    "type": "module",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3-monorepo"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "wt-nx-status": "./bin/node/nx-status.ts",
        "wt-prettier-status": "./bin/node/prettier-status.ts",
        "wt-workspace-status": "./bin/node/workspace-status.ts",
        "wt-repo-status": "./bin/python/repo_status.py",
        "wt-env-diagnostics": "./bin/python/env_diagnostics.py"
    }
}
