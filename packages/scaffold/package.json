{
    "name": "@snailicid3/scaffold",
    "version": "0.0.5",
    "private": true,
    "description": "Package scaffolding generator with TypeScript-function-based templates",
    "keywords": [
        "typescript",
        "snailicid3",
        "monorepo",
        "scaffold",
        "generator",
        "template",
        "cli"
    ],
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "dev:nx": "nx run $npm_package_name:dev",
        "test:coverage": "vitest run --coverage"
    },
    "bin": {
        "scaffold": "./bin/scaffold.ts"
    },
    "buildConfig": {
        "runtime": "node",
        "product": "cli",
        "buildStrategy": "bundle"
    },
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "build:ts": {},
            "check:ts": {},
            "build": {},
            "build:tsdown": {},
            "api:report": {},
            "api:check": {},
            "test": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types",
        "bin"
    ],
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3",
        "directory": "packages/scaffold"
    },
    "dependencies": {
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/cli-app": "workspace:*",
        "@snailicid3/node-utils": "workspace:*",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@microsoft/api-extractor": "^7.58.8",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.9.2",
        "tsdown": "^0.22.2",
        "typescript": "^6.0.2",
        "vitest": "^4.1.8"
    },
    "module": "./dist/index.mjs"
}
