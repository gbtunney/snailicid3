{
    "name": "@snailicid3/types",
    "version": "0.0.1",
    "private": false,
    "description": "Pure TypeScript types, utility types and typeguards",
    "keywords": [
        "typescript",
        "snailicid3",
        "monorepo",
        "types",
        "typeguards",
        "utility-types"
    ],
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean"
    },
    "buildConfig": {
        "runtime": "universal",
        "product": "library",
        "buildStrategy": "bundle"
    },
    "nx": {
        "targets": {
            "build:ts": {},
            "check:ts": {},
            "build:tsdown": {},
            "build": {
                "dependsOn": [
                    "build:ts",
                    "build:tsdown"
                ]
            },
            "test": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3",
        "directory": "packages/types"
    },
    "dependencies": {
        "ramda": "^0.32.0",
        "ramda-adjunct": "^6.0.0",
        "type-fest": "^5.5.0"
    },
    "devDependencies": {
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.6.1",
        "@types/ramda": "^0.31.1",
        "tsdown": "^0.22.0",
        "typescript": "^6.0.2",
        "vitest": "^4.1.4"
    }
}
