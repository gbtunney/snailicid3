{
    "name": "@snailicid3/types",
    "version": "0.0.3",
    "private": false,
    "description": "Pure TypeScript types, utility types and typeguards",
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "api:report:nx": "nx run $npm_package_name:api:report"
    },
    "buildConfig": {
        "runtime": "universal",
        "product": "library",
        "buildStrategy": "bundle"
    },
    "nx": {
        "targets": {
            "build:ts": {},
            "check:ts": {},
            "build:tsdown": {},
            "build": {},
            "api:report": {},
            "api:check": {},
            "test": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "typescript",
        "typeguards",
        "utility-types",
        "assertions"
    ],
    "type": "module",
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3",
        "directory": "packages/types"
    },
    "dependencies": {
        "ramda": "^0.32.0",
        "ramda-adjunct": "^6.1.0",
        "type-fest": "^5.7.0"
    },
    "devDependencies": {
        "@microsoft/api-extractor": "^7.58.8",
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^26.1.1",
        "@types/ramda": "^0.32.0",
        "tsdown": "^0.22.2",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.cts"
}
