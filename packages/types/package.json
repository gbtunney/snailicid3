{
    "name": "@snailicid3/types",
    "version": "0.0.0",
    "private": false,
    "description": "Pure TypeScript types, utility types and typeguards",
    "type": "module",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3-monorepo"
    },
    "main": "./dist/index.js",
    "types": "./types/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./types/index.d.ts"
        }
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "nx": {
        "targets": {
            "build:ts": {},
            "check:ts": {},
            "build": {
                "dependsOn": [
                    "build:ts"
                ]
            },
            "test": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "\n========== TEST >> ==========": "",
        "test:watch": "vitest watch",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "ramda": "^0.32.0",
        "ramda-adjunct": "^6.0.0",
        "type-fest": "^5.5.0"
    },
    "devDependencies": {
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.6.0",
        "@types/ramda": "^0.31.1",
        "typescript": "^6.0.2",
        "vitest": "^4.1.4"
    },
    "publishConfig": {
        "access": "public"
    }
}
