{
    "name": "@snailicid3/config",
    "version": "0.1.1",
    "private": false,
    "description": "Shared linting, formatting, and TypeScript config utilities for the snailicid3 monorepo",
    "keywords": [
        "typescript",
        "monorepo",
        "eslint",
        "prettier",
        "markdownlint",
        "commitlint",
        "linting",
        "formatting",
        "snail-sh"
    ],
    "scripts": {
        "build:exporter": "pnpm exec node ./dist/build-exporter.js",
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "dev:nx": "nx run $npm_package_name:dev",
        "api:report:nx": "nx run $npm_package_name:api:report",
        "demo:logger": "pnpm exec ./bin/snail-sh-test.sh",
        "demo:2": "pnpm exec snail-sh header '🐌 SNAIL BUILD' '50%'  '~'"
    },
    "bin": {
        "snail-sh": "./bin/snail-sh-logger.sh",
        "scope-commit": "./bin/scope/commit.sh",
        "scope-affected": "./bin/scope/affected.sh",
        "gbt-changeset": "./bin/changeset-branch.sh",
        "gbt-setup": "./bin/completions/install-pnpm.sh",
        "gbt-uninstall": "./bin/uninstall.sh"
    },
    "buildConfig": {
        "runtime": "node",
        "product": "config",
        "buildStrategy": "none"
    },
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "build:ts": {},
            "check:ts": {},
            "build:exporter": {
                "cache": true,
                "dependsOn": [
                    "build:ts"
                ],
                "inputs": [
                    "{projectRoot}/src/build-exporter.ts",
                    "{projectRoot}/src/api-extractor/**/*",
                    "{projectRoot}/src/prettier/**/*",
                    "{projectRoot}/src/markdownlint/**/*"
                ],
                "outputs": [
                    "{projectRoot}/dist/.prettierrc.json",
                    "{projectRoot}/dist/.markdownlint.json",
                    "{projectRoot}/dist/.api-extractor-base.json"
                ]
            },
            "api:report": {},
            "api:check": {},
            "build": {
                "dependsOn": [
                    "build:ts",
                    "build:exporter"
                ]
            },
            "test": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./types/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./types/index.d.ts"
        },
        "./prettier": "./dist/.prettierrc.json",
        "./markdownlint": "./dist/.markdownlint.json",
        "./tsconfig/base": "./typescript-config/tsconfig.base.json",
        "./api-extractor/base.json": "./dist/.api-extractor-base.json",
        "./tsconfig/library": "./typescript-config/tsconfig.library.json",
        "./tsconfig/typecheck": "./typescript-config/tsconfig.typecheck.json",
        "./tsconfig/docs": "./typescript-config/tsconfig.docs.json",
        "./tsconfig.base": "./typescript-config/tsconfig.base.json",
        "./tsconfig.library": "./typescript-config/tsconfig.library.json",
        "./tsconfig.typecheck": "./typescript-config/tsconfig.typecheck.json",
        "./tsconfig.docs": "./typescript-config/tsconfig.docs.json"
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types",
        "typescript-config",
        "bin",
        "completions"
    ],
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3",
        "directory": "packages/config"
    },
    "dependencies": {
        "@apidevtools/json-schema-ref-parser": "^15.3.5",
        "@commitlint/config-conventional": "^21.0.2",
        "@commitlint/types": "^21.0.1",
        "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
        "@eslint/config-helpers": "^0.6.0",
        "@eslint/js": "^10.0.1",
        "@prettier/plugin-php": "^0.25.0",
        "@prettier/plugin-xml": "^3.4.2",
        "@types/json-schema": "^7.0.15",
        "@types/micromatch": "^4.0.10",
        "@types/yargs": "^17.0.35",
        "@vitest/eslint-plugin": "^1.6.20",
        "ajv": "^8.20.0",
        "eslint": "^10.4.1",
        "eslint-plugin-check-file": "^3.3.1",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-jsdoc": "^63.0.4",
        "eslint-plugin-perfectionist": "^5.9.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "eslint-plugin-storybook": "^10.4.5",
        "eslint-plugin-unicorn": "^68.0.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.6.0",
        "json-schema": "^0.4.0",
        "json-schema-to-typescript": "^15.0.4",
        "jsonc-parser": "^3.3.1",
        "lint-staged": "^17.0.7",
        "markdownlint-cli2": "^0.22.1",
        "micromatch": "^4.0.8",
        "prettier": "^3.8.4",
        "prettier-plugin-jsdoc": "^1.8.1",
        "prettier-plugin-sh": "^0.18.1",
        "remark-toc": "^9.0.0",
        "ts-deepmerge": "^8.0.0",
        "type-fest": "^5.7.0",
        "typedoc": "^0.28.19",
        "typedoc-material-theme": "^1.4.1",
        "typedoc-plugin-markdown": "^4.12.0",
        "typedoc-plugin-remark": "^2.0.1",
        "typedoc-plugin-zod": "^1.4.3",
        "typedoc-vitepress-theme": "^1.1.3",
        "typescript-eslint": "^8.61.1",
        "unified-prettier": "^2.0.1",
        "yargs": "^18.0.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@microsoft/api-extractor": "^7.58.8",
        "@types/node": "26.0.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    }
}
