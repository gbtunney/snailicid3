{
    "name": "@snailicid3/config",
    "version": "0.0.0",
    "private": false,
    "description": "Shared linting, formatting, and TypeScript config utilities for the snailicid3 monorepo",
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        
        
        "\n========== DEVELOPMENT >> ==========": "",
        "dev": "tsc --build --watch",
        "\n========== TEST >> ==========": "",
        "test:watch": "vitest watch",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@commitlint/types": "^20.5.0",
        "@eslint/js": "^10.0.1",
        "@types/json-schema": "^7.0.15",
        "eslint-plugin-eslint-comments": "^3.2.0",
        "eslint-plugin-filenames-simple": "^0.9.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^62.9.0",
        "eslint-plugin-sort": "^4.0.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "eslint-plugin-vitest": "^0.5.4",
        "globals": "^17.4.0",
        "prettier-plugin-jsdoc": "^1.8.0",
        "ts-deepmerge": "^7.0.3",
        "type-fest": "^4.41.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@apidevtools/json-schema-ref-parser": "^15.3.5",
        "@types/node": "^22.0.0",
        "ajv": "^8.18.0",
        "json-schema": "^0.4.0",
        "json-schema-to-typescript": "^15.0.4",
        "typescript": "^5.7.0",
        "vitest": "^2.1.0"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./tsconfig-base": "./tsconfig-base.json"
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "tsconfig-base.json"
    ],
    "keywords": [
        "eslint",
        "prettier",
        "typescript",
        "config"
    ],
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:rollup": {},
            "dev:vite": {},
            "build:ts": {},
            "build:rollup": {},
            "build:vite": {},
            "build": {
                "dependsOn": [
                    "build:ts"
                ]
            },
            "test": {},
            "test:nx": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {},
            "docs:build": {}
        }
    },
    "type": "module",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3-monorepo"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
}