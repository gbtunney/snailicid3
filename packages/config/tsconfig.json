{
    "extends": "./typescript-config/tsconfig.typecheck.json",
    "exclude": ["./node_modules"],
    "files": ["package.json"],
    "include": [
        "./*.ts",
        "./*.cts",
        "./*.mts",
        "./src/**/*.ts",
        "./src/**/*.cts",
        "./src/**/*.mts",
        "./**/*.test.ts",
        "./**/*.test.mts",
        "./**/*.test.cts"
    ]
}
