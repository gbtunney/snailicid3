{
    "name": "@snailicid3/cli-app",
    "version": "0.0.0",
    "private": true,
    "description": "Zod-backed CLI app framework",
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "dev:nx": "nx run $npm_package_name:dev",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/color": "workspace:*",
        "@snailicid3/logger": "workspace:*",
        "@snailicid3/node-utils": "workspace:*",
        "@snailicid3/types": "workspace:*",
        "@snailicid3/utils": "workspace:*",
        "@types/yargs-interactive": "^2.1.6",
        "add": "^2.0.6",
        "chalk": "^5.6.2",
        "figlet": "^1.11.0",
        "type-fest": "^5.5.0",
        "yargs": "^18.0.0",
        "yargs-interactive": "^3.0.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.6.0",
        "@types/yargs": "^17.0.35",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.2",
        "vitest": "^4.1.4"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./types/index.d.ts"
        }
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:rollup": {},
            "dev:vite": {},
            "build:ts": {},
            "check:ts": {},
            "build:rollup": {},
            "build:vite": {},
            "build": {
                "dependsOn": [
                    "build:ts"
                ]
            },
            "test": {},
            "test:nx": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {},
            "docs:build:ts": {},
            "docs:build": {}
        }
    },
    "type": "module",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3-monorepo"
    },
    "main": "./dist/index.js",
    "types": "./types/index.d.ts"
}
