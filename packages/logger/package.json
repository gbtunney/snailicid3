{
    "name": "@snailicid3/logger",
    "version": "0.0.5",
    "private": false,
    "description": "Unified Node logger with chalk output and shell script counterpart",
    "keywords": [
        "typescript",
        "snailicid3",
        "monorepo",
        "logger",
        "chalk",
        "logging",
        "node"
    ],
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "dev:nx": "nx run $npm_package_name:dev",
        "demo": "node ./bin/logger-demo.js"
    },
    "buildConfig": {
        "runtime": "node",
        "product": "library",
        "buildStrategy": "bundle"
    },
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:tsdown": {},
            "build:ts": {},
            "check:ts": {},
            "build:tsdown": {},
            "build": {},
            "api:report": {},
            "api:check": {},
            "test": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./demo": "./dist/demo.mjs",
        "./package.json": "./package.json"
    },
    "files": [
        "CHANGELOG.md",
        "bin",
        "dist",
        "types"
    ],
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3",
        "directory": "packages/logger"
    },
    "dependencies": {
        "@snailicid3/color": "workspace:*",
        "@snailicid3/utils": "workspace:*",
        "chalk": "^5.6.2",
        "dayjs": "^1.11.20"
    },
    "devDependencies": {
        "@microsoft/api-extractor": "^7.58.7",
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.8.0",
        "tsdown": "^0.22.0",
        "typescript": "^6.0.2",
        "vitest": "^4.1.4"
    },
    "module": "./dist/index.js"
}
