{
    "name": "@snailicid3/logger",
    "version": "0.0.1",
    "private": false,
    "description": "Unified Node logger with chalk output and shell script counterpart",
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "dev:nx": "nx run $npm_package_name:dev",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@snailicid3/color": "workspace:*",
        "@snailicid3/utils": "workspace:*",
        "chalk": "^5.6.2",
        "dayjs": "^1.11.20",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.2",
        "vitest": "^4.1.4"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./types/index.d.ts"
        }
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:rollup": {},
            "build:ts": {},
            "check:ts": {},
            "build:rollup": {},
            "build": {
                "dependsOn": [
                    "build:ts"
                ]
            },
            "test": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "type": "module",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3-monorepo"
    },
    "main": "./dist/index.js",
    "types": "./types/index.d.ts"
}
