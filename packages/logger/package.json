{
    "name": "@snailicid3/logger",
    "version": "0.0.1",
    "private": false,
    "description": "Unified Node logger with chalk output and shell script counterpart",
    "keywords": [
        "typescript",
        "snailicid3",
        "monorepo",
        "logger",
        "chalk",
        "logging",
        "node"
    ],
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "dev:nx": "nx run $npm_package_name:dev",
        "test:coverage": "vitest run --coverage"
    },
    "buildConfig": {
        "runtime": "node",
        "product": "library",
        "buildStrategy": "bundle"
    },
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:tsdown": {},
            "build:ts": {},
            "check:ts": {},
            "build:tsdown": {},
            "build": {
                "dependsOn": [
                    "build:ts",
                    "build:tsdown"
                ]
            },
            "test": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./types/index.d.ts",
    "exports": {
        ".": {
            "types": "./types/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3",
        "directory": "packages/logger"
    },
    "dependencies": {
        "@snailicid3/color": "workspace:*",
        "@snailicid3/utils": "workspace:*",
        "chalk": "^5.6.2",
        "dayjs": "^1.11.20",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.6.0",
        "tsdown": "^0.21.10",
        "typescript": "^6.0.2",
        "vitest": "^4.1.4"
    }
}
