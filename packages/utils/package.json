{
    "name": "@snailicid3/utils",
    "version": "0.0.0",
    "private": false,
    "description": "String, numeric, object, date and fmt utilities",
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "\n========== DEVELOPMENT >> ==========": "",
        "dev": "tsc --build --watch",
        "\n========== TEST >> ==========": "",
        "test:watch": "vitest watch",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "type-fest": "^4.26.0",
        "flat": "^6.0.1",
        "ts-deepmerge": "^7.0.0",
        "dayjs": "^1.11.13",
        "@snailicid3/types": "workspace:*"
    },
    "devDependencies": {
        "@snailicid3/config": "workspace:*",
        "@types/node": "^22.0.0",
        "typescript": "^5.7.0",
        "vitest": "^2.1.0"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "CHANGELOG.md",
        "dist"
    ],
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:rollup": {},
            "dev:vite": {},
            "build:ts": {},
            "build:rollup": {},
            "build:vite": {},
            "build": {
                "dependsOn": [
                    "build:ts"
                ]
            },
            "test": {},
            "test:nx": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {},
            "docs:build": {}
        }
    },
    "type": "module",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3-monorepo"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
}
