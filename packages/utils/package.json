{
    "name": "@snailicid3/utils",
    "version": "0.0.5",
    "private": false,
    "description": "String, numeric, object, date and fmt utilities",
    "keywords": [
        "typescript",
        "snailicid3",
        "monorepo",
        "utilities",
        "string",
        "numeric",
        "date",
        "format"
    ],
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "docs:nx": "nx run $npm_package_name:docs:build",
        "docs:serve:nx": "nx run $npm_package_name:docs:serve",
        "api:report:nx": "nx run $npm_package_name:api:report"
    },
    "buildConfig": {
        "runtime": "universal",
        "product": "library",
        "buildStrategy": "bundle"
    },
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:tsdown": {},
            "build:ts": {},
            "build:tsdown": {},
            "build": {},
            "api:report": {},
            "api:check": {},
            "check:ts": {},
            "test": {},
            "test:nx": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {},
            "docs:build": {},
            "docs:build:ts": {},
            "docs:serve": {}
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3",
        "directory": "packages/utils"
    },
    "dependencies": {
        "@snailicid3/types": "workspace:*",
        "dayjs": "^1.11.21",
        "escape-string-regexp": "^5.0.0",
        "flat": "^6.0.1",
        "minimatch": "^10.2.5",
        "ramda": "^0.32.0",
        "ramda-adjunct": "^6.1.0",
        "semver": "^7.8.4",
        "sprintf-js": "^1.1.3",
        "ts-deepmerge": "^8.0.0",
        "type-fest": "^5.7.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@microsoft/api-extractor": "^7.58.8",
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.9.2",
        "@types/ramda": "^0.31.1",
        "@types/semver": "^7.7.1",
        "@types/sprintf-js": "^1.1.4",
        "tsdown": "^0.22.2",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.2",
        "vitest": "^4.1.8"
    },
    "module": "./dist/index.js",
    "inlinedDependencies": {
        "balanced-match": "4.0.3",
        "brace-expansion": "5.0.6",
        "dayjs": "1.11.21",
        "escape-string-regexp": "5.0.0",
        "flat": "6.0.1",
        "minimatch": "10.2.5",
        "ramda": "0.32.0",
        "ramda-adjunct": "6.1.0",
        "semver": "7.8.4",
        "sprintf-js": "1.1.3",
        "zod": "4.4.3"
    }
}
