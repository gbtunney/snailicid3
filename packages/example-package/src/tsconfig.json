{
    "extends": "@snailicid3/config/tsconfig-base",
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "../dist",
        "declarationDir": "../types",
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "lib": ["ESNext", "DOM"],
        "types": ["node"]
    },
    "include": ["**/*.ts", "**/*.cts", "**/*.mts"],
    "exclude": [
        "**/*.test.ts",
        "**/*.test.mts",
        "**/*.test.cts",
        "**/*.spec.ts",
        "**/*.spec.mts",
        "**/*.spec.cts"
    ]
}

