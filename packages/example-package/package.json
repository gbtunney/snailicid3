{
    "name": "@snailicid3/example-package",
    "version": "0.0.0",
    "private": true,
    "description": "Example monorepo package",
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "dev:nx": "nx run $npm_package_name:dev",
        "test:coverage": "vitest run --coverage"
    },
    "devDependencies": {
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.2",
        "vitest": "^4.1.4"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./types/index.d.ts"
        }
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:tsdown": {},
            "dev:vite": {},
            "build:ts": {},
            "check:ts": {},
            "build:tsdown": {},
            "build:vite": {},
            "build": {
                "dependsOn": [
                    "build:tsdown"
                ]
            },
            "test": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "type": "module",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3-monorepo"
    },
    "main": "./dist/index.js",
    "types": "./types/index.d.ts",
    "buildConfig": {
        "runtime": "node",
        "product": "library",
        "buildStrategy": "bundle"
    }
}
