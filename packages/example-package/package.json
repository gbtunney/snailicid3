{
    "name": "@snailicid3/example-package",
    "version": "0.0.0",
    "private": true,
    "description": "Example monorepo package",
    "keywords": [
        "typescript",
        "snailicid3",
        "monorepo",
        "example",
        "template",
        "boilerplate"
    ],
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "dev:nx": "nx run $npm_package_name:dev",
        "test:coverage": "vitest run --coverage"
    },
    "buildConfig": {
        "runtime": "universal",
        "product": "library",
        "buildStrategy": "bundle"
    },
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:tsdown": {},
            "dev:vite": {},
            "build:ts": {},
            "check:ts": {},
            "build:tsdown": {},
            "build:vite": {},
            "build": {},
            "test": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "browser": "./dist/index-iife.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3",
        "directory": "packages/example-package"
    },
    "devDependencies": {
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.6.0",
        "tsdown": "^0.21.10",
        "typescript": "^6.0.2",
        "vitest": "^4.1.4"
    }
}
