{
    "name": "@snailicid3/node-utils",
    "version": "0.0.0",
    "private": false,
    "description": "Node.js filesystem, path and package.json utilities",
    "type": "module",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
