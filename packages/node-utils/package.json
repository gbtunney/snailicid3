{
    "name": "@snailicid3/node-utils",
    "version": "0.0.5",
    "private": false,
    "description": "Node.js filesystem, path and package.json utilities",
    "keywords": [
        "typescript",
        "snailicid3",
        "monorepo",
        "node",
        "filesystem",
        "path",
        "glob",
        "yargs"
    ],
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "dev:nx": "nx run $npm_package_name:dev",
        "api:report:nx": "nx run $npm_package_name:api:report"
    },
    "buildConfig": {
        "runtime": "node",
        "product": "library",
        "buildStrategy": "bundle"
    },
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:tsdown": {},
            "check:ts": {},
            "build:ts": {},
            "build:tsdown": {},
            "build": {},
            "api:report": {},
            "api:check": {},
            "test": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3",
        "directory": "packages/node-utils"
    },
    "dependencies": {
        "@snailicid3/types": "workspace:*",
        "@snailicid3/utils": "workspace:*",
        "@types/is-glob": "^4.0.4",
        "glob": "^13.0.6",
        "is-glob": "^4.0.3",
        "ramda-adjunct": "^6.1.0",
        "type-fest": "^5.7.0",
        "yargs": "^18.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@microsoft/api-extractor": "^7.58.8",
        "@snailicid3/build-config": "workspace:*",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^26.1.1",
        "@types/yargs": "^17.0.35",
        "tsdown": "^0.22.2",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "module": "./dist/index.mjs"
}
