{
    "name": "@snailicid3/build-config",
    "version": "0.0.6",
    "private": false,
    "description": "Shared tsdown, vite, vitest and typedoc build tool configs",
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "api:report:nx": "nx run $npm_package_name:api:report"
    },
    "buildConfig": {
        "runtime": "node",
        "product": "build_tool",
        "buildStrategy": "none"
    },
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "build:ts": {},
            "check:ts": {},
            "build": {
                "dependsOn": [
                    "build:ts"
                ]
            },
            "api:report": {},
            "api:check": {},
            "test": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "typescript",
        "snailicid3",
        "monorepo",
        "rollup",
        "vite",
        "tsdown",
        "vitest",
        "typedoc",
        "build",
        "bundler"
    ],
    "type": "module",
    "main": "./dist/index.js",
    "types": "./types/index.d.ts",
    "exports": {
        ".": {
            "types": "./types/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3",
        "directory": "packages/build-config"
    },
    "dependencies": {
        "@arethetypeswrong/core": "^0.18.3",
        "@rollup/plugin-commonjs": "^29.0.3",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "attw": "^1.0.0",
        "esbuild": "^0.28.0",
        "publint": "^0.3.21",
        "remark-toc": "^9.0.0",
        "rollup": "^4.61.1",
        "rollup-plugin-node-externals": "^9.0.1",
        "rollup-plugin-polyfill-node": "^0.13.0",
        "ts-deepmerge": "^8.0.0",
        "ts-extras": "^1.0.0",
        "tsdown": "^0.22.2",
        "type-fest": "^5.7.0",
        "typedoc": "^0.28.19",
        "typedoc-material-theme": "^1.4.1",
        "typedoc-plugin-markdown": "^4.12.0",
        "typedoc-plugin-remark": "^2.0.1",
        "typedoc-plugin-zod": "^1.4.3",
        "unified-prettier": "^2.0.1",
        "unplugin-unused": "^0.5.7",
        "vite": "^8.0.16",
        "vite-plugin-dts": "^5.0.2",
        "zod": "^4.4.2"
    },
    "devDependencies": {
        "@microsoft/api-extractor": "^7.58.8",
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.9.2",
        "typescript": "^6.0.2",
        "vitest": "^4.1.8"
    }
}
