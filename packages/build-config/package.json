{
    "name": "@snailicid3/build-config",
    "version": "0.0.1",
    "private": false,
    "description": "Shared rollup, vite, vitest and typedoc build tool configs",
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "\n========== TEST >> ==========": "",
        "test:coverage": "vitest run --coverage"
    },
    "devDependencies": {
        "@snailicid3/config": "workspace:*",
        "@types/node": "^25.6.0",
        "rollup": "^4.60.1",
        "tslib": "^2.8.1",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.2",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./types/index.d.ts"
        }
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:rollup": {},
            "dev:vite": {},
            "build:ts": {},
            "check:ts": {},
            "build:rollup": {},
            "build:vite": {},
            "build": {
                "dependsOn": [
                    "build:ts"
                ]
            },
            "test": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "type": "module",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/snailicid3-monorepo"
    },
    "main": "./src/index.js",
    "types": "./types/index.d.ts",
    "dependencies": {
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "remark-toc": "^9.0.0",
        "rollup-plugin-node-externals": "^9.0.1",
        "rollup-plugin-polyfill-node": "^0.13.0",
        "ts-deepmerge": "^7.0.3",
        "type-fest": "^5.6.0",
        "typedoc-material-theme": "^1.4.1",
        "typedoc-plugin-markdown": "^4.11.0",
        "typedoc-plugin-remark": "^2.0.1",
        "typedoc-plugin-zod": "^1.4.3",
        "unified-prettier": "^2.0.1"
    }
}
