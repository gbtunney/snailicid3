{
    "namedInputs": {
        "default": ["{projectRoot}/**/*", "sharedGlobals"],
        "production": [
            "default",
            "!{projectRoot}/**/*.test.*",
            "!{projectRoot}/**/*.spec.*",
            "!{projectRoot}/**/*.stories.*"
        ],
        "sharedGlobals": [
            "{workspaceRoot}/tsconfig.json",
            "{workspaceRoot}/pnpm-lock.yaml",
            "{workspaceRoot}/eslint.config.ts",
            "{workspaceRoot}/pnpm-workspace.yaml"
        ]
    },
    "targetDefaults": {
        "nx:test:cmd": {
            "command": "echo 'hi ths is an override;'",
            "options": { "cwd": "{projectRoot}" }
        },
        "build:ts": {
            "cache": true,
            "dependsOn": ["^build"],
            "inputs": ["production", "^production"],
            "outputs": ["{projectRoot}/dist"],
            "command": "tsc --build",
            "options": { "cwd": "{projectRoot}" }
        },
        "build:rollup": {
            "cache": true,
            "dependsOn": ["build:ts"],
            "inputs": ["production", "^production"],
            "outputs": ["{projectRoot}/dist"],
            "command": "rollup --config ./rollup.config.mts",
            "options": { "cwd": "{projectRoot}" }
        },
        "build:vite": {
            "cache": true,
            "dependsOn": ["build:ts"],
            "inputs": ["production", "^production"],
            "outputs": ["{projectRoot}/dist"],
            "command": "vite build",
            "options": { "cwd": "{projectRoot}" }
        },
        "build": {
            "cache": true,
            "dependsOn": ["build:ts", "build:rollup"],
            "inputs": ["production", "^production"]
        },
        "test": {
            "cache": true,
            "dependsOn": ["build", "^test"],
            "inputs": ["default", "^default"],
            "command": "vitest run",
            "options": { "cwd": "{projectRoot}" }
        },
        "lint": {
            "cache": true,
            "inputs": ["default", "^default"],
            "command": "eslint --flag unstable_ts_config .",
            "options": { "cwd": "{projectRoot}" }
        },
        "typecheck": {
            "cache": true,
            "inputs": ["default", "^default"],
            "command": "tsc --noEmit",
            "options": { "cwd": "{projectRoot}" }
        },
        "fix": {
            "cache": false,
            "command": "prettier --write . && eslint --flag unstable_ts_config . --fix",
            "options": { "cwd": "{projectRoot}" }
        },
        "clean:ts": {
            "cache": false,
            "command": "tsc --build --clean",
            "options": { "cwd": "{projectRoot}" }
        },
        "clean:build": {
            "cache": false,
            "command": "rm -rf ./dist ./types",
            "options": { "cwd": "{projectRoot}" }
        },
        "clean": {
            "cache": false,
            "dependsOn": ["clean:ts", "clean:build"]
        },
        "docs:build": {
            "cache": true,
            "dependsOn": ["build", "^docs:build"],
            "inputs": ["production", "^production"],
            "outputs": ["{projectRoot}/docs"],
            "command": "typedoc",
            "options": { "cwd": "{projectRoot}" }
        }
    },
    "analytics": true
}
