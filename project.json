{
    "$schema": "./node_modules/nx/schemas/project-schema.json",
    "name": "root",
    "projectType": "library",
    "targets": {
        "build": {
            "dependsOn": ["build:ts"]
        },

        "build:ts": {
            "cache": true,
            "dependsOn": [
                { "projects": ["@snailicid3/config"], "target": "build" }
            ],
            "inputs": [
                "{projectRoot}/*.ts",
                "{projectRoot}/*.mts",
                "{projectRoot}/*.cts",
                "{projectRoot}/tsconfig.json"
            ],
            "outputs": [
                "{projectRoot}/*.js",
                "{projectRoot}/*.mjs",
                "{projectRoot}/*.cjs"
            ],
            "command": "tsc --build tsconfig.json",
            "options": { "cwd": "{projectRoot}" }
        },

        "clean:ts": {
            "cache": false,
            "command": "tsc --build --clean tsconfig.json",
            "options": { "cwd": "{projectRoot}" }
        },
        "clean": {
            "cache": false,
            "dependsOn": ["clean:ts"]
        },
        "lint": {
            "cache": false,
            "dependsOn": ["build:ts"],
            "command": "prettier --check \"{*,.*}.{ts,tsx,mts,cts,json,yaml,yml,md,sh}\" \".github/**/*.{yaml,yml}\" \".husky/*\" --no-error-on-unmatched-pattern && eslint --config eslint.config.ts ./*.ts ./*.mts ./*.cts",
            "options": { "cwd": "{projectRoot}" }
        },
        "fix": {
            "cache": false,
            "dependsOn": ["build:ts"],
            "command": "prettier --write \"{*,.*}.{ts,tsx,mts,cts,json,yaml,yml,md,sh}\" \".github/**/*.{yaml,yml}\" \".husky/*\" --no-error-on-unmatched-pattern && eslint --config eslint.config.ts ./*.ts ./*.mts ./*.cts --fix",
            "options": { "cwd": "{projectRoot}" }
        },
        "lint:md": {
            "cache": true,
            "inputs": ["{projectRoot}/*.md"],
            "command": "markdownlint-cli2 \"./*.md\" \"#**/node_modules/**\"",
            "options": { "cwd": "{projectRoot}" }
        }
    }
}
